{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "importSort": {
    "enabled": true
  },
  "sortPackageJson": {},
  "ignorePatterns": ["node_modules", ".next", "out", "dist", "public", "*.generated.ts"]
}
